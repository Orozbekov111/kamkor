<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Kamkor</string>
	<!-- Alternate app icons for the in-app icon switcher (Profile →
	     «Иконка приложения»). Files live loose in Runner/AppIcons and are
	     copied to the bundle root (see project.pbxproj). The primary icon
	     (Kamkor) stays in Assets.xcassets and is restored by passing null. -->
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<key>calculator</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>calculator</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>notes</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>notes</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>weather</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>weather</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>clock</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>clock</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>calendar</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>calendar</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>gallery</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>gallery</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
		</dict>
	</dict>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>kamkor</string>
	<key>CFBundleLocalizations</key>
	<array>
		<string>ky</string>
		<string>ru</string>
	</array>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>Камера нужна для сканирования QR-кода персональной ссылки входа.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Геолокация нужна, чтобы передать спасателям ваше местоположение во время тревоги SOS.</string>
	<key>NSContactsUsageDescription</key>
	<string>Доступ к контактам нужен, чтобы добавить доверенный контакт из вашей телефонной книги.</string>
	<!-- Schemes url_launcher must be able to probe: calling contacts (tel)
	     and opening recorded coordinates in the 2GIS app (dgis). -->
	<key>LSApplicationQueriesSchemes</key>
	<array>
		<string>tel</string>
		<string>dgis</string>
	</array>
</dict>
</plist>
